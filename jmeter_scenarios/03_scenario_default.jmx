              <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor" testname="REGEXPEXT classic_chunk_id" enabled="true">
                <stringProp name="RegexExtractor.useHeaders">false</stringProp>
                <stringProp name="RegexExtractor.refname">classic_chunk_id</stringProp>
                <stringProp name="RegexExtractor.regex">(\d+)\s*:\s*&quot;([a-f0-9]+)&quot;</stringProp>
                <stringProp name="RegexExtractor.template">$1$</stringProp>
                <stringProp name="RegexExtractor.default">NOT_FOUND</stringProp>
