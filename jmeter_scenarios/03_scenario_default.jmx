              <hashTree/>
              <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">try {
    // 1. Получаем ответ в виде обычной строки
    def response = prev.getResponseDataAsString()
    
    // 2. Ищем паттерн &quot;id&quot;:&quot;число-число&quot; с помощью регулярного выражения
    def matcher = response =~ /&quot;id&quot;\s*:\s*&quot;(\d+)-(\d+)&quot;/
    
    if (matcher.find()) {
        // matcher[0][2] — это вторая группа (\d+), то есть число после дефиса (99936)
        int currentNum = matcher[0][2].toInteger()
        
        // 3. Инкрементируем число
        int nextNum = currentNum + 1
        def ISSUE_NUM = &quot;DEMO-${nextNum}&quot;
        // 4. Перезаписываем переменную RND_ISSUE
        vars.put(&quot;RND_ISSUE&quot;, ISSUE_NUM)
        
        log.info(&quot;!!! НАТИВНЫЙ СКРИПТ СРАБОТАЛ !!! Новое значение RND_ISSUE: &quot; + vars.get(&quot;RND_ISSUE&quot;))
    } else {
        log.error(&quot;Регулярное выражение не нашло ID формата &apos;число-число&apos; в ответе: &quot; + response)
    }
} catch (Exception e) {
    log.error(&quot;Ошибка в нативном JSR223 скрипте: &quot; + e.getMessage())
}</stringProp>
              </JSR223PostProcessor>
              <hashTree/>
            </hashTree>
          </hashTree>
