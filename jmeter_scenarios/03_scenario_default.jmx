      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Select Random issue for search from pool of issues">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">def pool = props.get(&quot;GLOBAL_ISSUE_POOL&quot;)

if (pool) {
    def randomIndex = new Random().nextInt(pool.size())
    def randomNum = pool[randomIndex]
    
    def ISSUE_NUM = &quot;DEMO-${randomNum}&quot;
    vars.put(&quot;RND_ISSUE&quot;, ISSUE_NUM)
} else {
    log.error(&quot;&gt;&gt;&gt; ERROR. NO pull of tickets check setUp Thread Group.&quot;)
    vars.put(&quot;RND_ISSUE&quot;, &quot;DEMO-ERROR&quot;)
}</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
