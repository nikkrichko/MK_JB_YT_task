                <stringProp name="parameters"></stringProp>
                <stringProp name="script">// Получаем индекс текущей итерации вложенного цикла
def idx = vars.get(&quot;__jm__ForEach_Classic_Chunks__idx&quot;).toInteger() + 1

// Вытаскиваем хэш из параллельного массива хэшей
def matchingHash = vars.get(&quot;classic_chunk_hash_&quot; + idx)

// Сохраняем в переменную для отправки запроса
vars.put(&quot;current_classic_chunk_hash&quot;, matchingHash)</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
              </JSR223PreProcessor>
