      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Gtenerate pool of random 50 tickets for future search">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">def uniqueNumbers = new HashSet&lt;Integer&gt;()
def rand = new Random()

while (uniqueNumbers.size() &lt; 50) {
    def num = rand.nextInt(100000) + 1
    uniqueNumbers.add(num)
}

def pool = uniqueNumbers.toList()

props.put(&quot;GLOBAL_ISSUE_POOL&quot;, pool)

log.info(&quot;&gt;&gt;&gt; SUCCESS: generate pool of random tickets for search&quot; + pool)</stringProp>
        </JSR223Sampler>
