              <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="false">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">// Получаем ответ в виде строки
var response = prev.getResponseDataAsString();

if (response) {
    // Парсим JSON стандартным методом JS
    var jsonResponse = JSON.parse(response);
    
    if (jsonResponse &amp;&amp; jsonResponse.length &gt; 0) {
        // Генерируем случайный индекс
        var randomIndex = Math.floor(Math.random() * jsonResponse.length);
        var randomObject = jsonResponse[randomIndex];
        
        // Записываем данные в переменные JMeter
        vars.put(&quot;random_id&quot;, randomObject.id.toString());
        vars.put(&quot;random_name&quot;, randomObject.name.toString());
        
        log.info(&quot;JS Нашел связку: ID=&quot; + randomObject.id + &quot;, Name=&quot; + randomObject.name);
    }
}</stringProp>
              </JSR223PostProcessor>
